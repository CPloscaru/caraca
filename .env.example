# fal.ai API key (required for image/video generation)
# Get yours at: https://fal.ai/dashboard/keys
FAL_KEY=

# OpenRouter API key (optional, enables LLM Assistant node)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_KEY=

# App URL used as HTTP-Referer for OpenRouter requests
# Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# SQLite database file path
# Default: caraca.db (in project root)
DATABASE_PATH=caraca.db

# Directory for uploaded/generated images
# Default: ./storage/images
IMAGE_STORAGE_PATH=./storage/images
